        function computeResult() {
            const rawScores = {};
            Object.keys(dimensionMeta).forEach(dim => rawScores[dim] = 0);

            questions.forEach(q => {
                rawScores[q.dim] += currentAnswers[q.id] || 0;
            });

            const sumToLevel = (score) => {
                if (score <= 3) return 'L';
                if (score === 4) return 'M';
                return 'H';
            };

            const levels = {};
            Object.entries(rawScores).forEach(([dim, score]) => {
                levels[dim] = sumToLevel(score);
            });

            const levelNum = (level) => ({ L: 1, M: 2, H: 3 }[level] || 0);
            const userVector = dimensionOrder.map(dim => levelNum(levels[dim]));

            const ranked = NORMAL_TYPES.map(type => {
                const pattern = type.pattern.replace(/-/g, '').split('');
                const vector = pattern.map(levelNum);
                let distance = 0;
                let exact = 0;
                for (let i = 0; i < vector.length; i++) {
                    const diff = Math.abs(userVector[i] - vector[i]);
                    distance += diff;
                    if (diff === 0) exact += 1;
                }
                const similarity = Math.max(0, Math.round((1 - distance / 30) * 100));
                return { ...type, ...TYPE_LIBRARY[type.code], distance, exact, similarity };
            }).sort((a, b) => {
                if (a.distance !== b.distance) return a.distance - b.distance;
                if (b.exact !== a.exact) return b.exact - a.exact;
                return b.similarity - a.similarity;
            });

            const bestNormal = ranked[0];
            const drunkTriggered = currentAnswers['drink_gate_q2'] === 2;

            let finalType;
            let modeKicker = '你的主类型';
            let badge = `匹配度 ${bestNormal.similarity}% · 精准命中 ${bestNormal.exact}/15 维`;
            let sub = '维度命中度较高，当前结果可视为你的第一人格画像';
            let special = false;

            if (drunkTriggered) {
                finalType = TYPE_LIBRARY.DRUNK;
                modeKicker = '隐藏人格已激活';
                badge = '匹配度 100% · 酒精异常因子已接管';
                sub = '乙醇亲和性过强，系统已直接跳过常规人格审判。';
                special = true;
            } else if (bestNormal.similarity < 60) {
                finalType = TYPE_LIBRARY.HHHH;
                modeKicker = '系统强制兜底';
                badge = `标准人格库最高匹配仅 ${bestNormal.similarity}%`;
                sub = '标准人格库对你的脑回路集体罢工了，于是系统把你强制分配给了 HHHH。';
                special = true;
            } else {
                finalType = bestNormal;
            }

            return { rawScores, levels, finalType, modeKicker, badge, sub, special };
        }

        function renderRadar(result) {
            const ctx = document.getElementById('radarChart').getContext('2d');
            if (radarChart) radarChart.destroy();

            radarChart = new Chart(ctx, {
                type: 'radar',
                data: {
                    labels: dimensionOrder,
                    datasets: [{
                        label: '维度得分',
                        data: dimensionOrder.map(dim => result.rawScores[dim]),
                        backgroundColor: 'rgba(108, 141, 113, 0.2)',
                        borderColor: '#4d6a53',
                        borderWidth: 2,
                        pointBackgroundColor: '#4d6a53'
                    }]
                },
                options: {
                    scales: {
                        r: {
                            min: 0,
                            max: 6,
                            ticks: { display: false, stepSize: 1 },
                            grid: { color: '#dbe8dd' },
                            angleLines: { color: '#dbe8dd' },
                            pointLabels: { font: { weight: 'bold' }, color: '#4d6a53' }
                        }
                    },
                    plugins: { legend: { display: false } },
                    maintainAspectRatio: false
                }
            });
        }

        function renderDimList(result) {
            const container = document.getElementById('dim-list');
            container.innerHTML = dimensionOrder.map(dim => {
                const level = result.levels[dim];
                const score = result.rawScores[dim];
                return `
                    <div class="p-4 rounded-xl border border-[#dbe8dd] bg-white space-y-2">
                        <div class="flex justify-between items-center">
                            <span class="font-bold text-[#1e2a22]">${dimensionMeta[dim].name}</span>
                            <span class="text-[#4d6a53] font-black">${level} / ${score}分</span>
                        </div>
                        <p class="text-sm text-[#6a786f] leading-relaxed">
                            ${DIM_EXPLANATIONS[dim][level]}
                        </p>
                    </div>
                `;
            }).join('');
        }

        function showToast(msg) {
            const toast = document.getElementById('toast');
            toast.textContent = msg;
            toast.style.opacity = '1';
            setTimeout(() => toast.style.opacity = '0', 2000);
        }

        function copyLink() {
            navigator.clipboard.writeText(window.location.href);
            showToast('测试链接已复制');
        }

        // 初始化
        init();
    </script>
</body>
</html>
